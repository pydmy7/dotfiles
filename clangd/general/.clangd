CompileFlags:
  Add:
    - -std=c++23

---
If:
  PathMatch: .*\.(cu|cuh)$
CompileFlags:
  Add:
    - --cuda-path=C:/Program Files/NVIDIA GPU Computing Toolkit/CUDA/v13.2/
    - -xcuda
    - -std=c++20
  Remove:
    - --expt-*
    - --generate-code=*
    - -arch=*
    - -rdc=*
    - -Xcompiler=*
    - -forward-unknown-to-host-compiler
    - -extended-lambda
    - -expt-relaxed-constexpr
    - -Xptxas=*
    - -res-usage
